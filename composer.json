{
    "name": "netglue/prismic-asset-api-client",
    "type": "project",
    "license": "MIT",
    "authors": [
        {
            "name": "George Steel",
            "email": "george@net-glue.co.uk"
        }
    ],
    "config": {
        "sort-packages": true,
        "allow-plugins": {
            "dealerdirect/phpcodesniffer-composer-installer": true,
            "php-http/discovery": false,
            "phpstan/extension-installer": true
        },
        "platform": {
            "php": "8.3.99"
        }
    },
    "require": {
        "php": "~8.3 || ~8.4",
        "cuyz/valinor": "^1.14",
        "fig/http-message-util": "^1.1",
        "psr/http-client": "^1.0",
        "psr/http-factory": "^1.1",
        "psr/http-message": "^2.0"
    },
    "require-dev": {
        "doctrine/coding-standard": "^12.0",
        "laminas/laminas-diactoros": "^3.5",
        "php-http/curl-client": "^2.3.3",
        "php-http/mock-client": "^1.6.1",
        "phpstan/extension-installer": "^1.4.3",
        "phpstan/phpstan": "^2.1.5",
        "phpstan/phpstan-phpunit": "^2.0.4",
        "phpstan/phpstan-strict-rules": "^2.0.3",
        "phpunit/phpunit": "^12.0.2",
        "psalm/plugin-phpunit": "^0.19.2",
        "squizlabs/php_codesniffer": "^3.11.3",
        "vimeo/psalm": "^6.5.1"
    },
    "autoload": {
        "psr-4": {
            "Prismic\\Asset\\": "src"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Prismic\\Asset\\Test\\Unit\\": "test/Unit"
        },
        "files": [
            "vendor/cuyz/valinor/qa/Psalm/ValinorPsalmPlugin.php"
        ]
    }
}
